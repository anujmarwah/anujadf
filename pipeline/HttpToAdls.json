{
	"name": "HttpToAdls",
	"properties": {
		"activities": [
			{
				"name": "HTTP_Ingestion",
				"type": "Copy",
				"state": "Inactive",
				"onInactiveMarkAs": "Succeeded",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"enableStaging": false
				}
			},
			{
				"name": "files_array",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "JsonSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "JsonReadSettings"
						}
					},
					"dataset": {
						"referenceName": "DSFilesArray",
						"type": "DatasetReference"
					}
				}
			}
		],
		"parameters": {
			"files_array": {
				"type": "array",
				"defaultValue": [
					{
						"file": "map_cities"
					},
					{
						"file": "map_cancellation_reasons"
					},
					{
						"file": "map_rides"
					},
					{
						"file": "map_payment_methods"
					},
					{
						"file": "map_ride_statuses"
					},
					{
						"file": "map_vehicle_makes"
					},
					{
						"file": "map_types"
					}
				]
			}
		},
		"annotations": []
	}
}